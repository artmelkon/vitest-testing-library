{
  "mcpServers": {
    "rest-api": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "dkmaker-mcp-rest-api"],
      "env": {
        "REST_BASE_URL": "http://localhost:5173",
        "HEADER_Accept": "application/json"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/arthurmelkonyan/webdev/vite-TESTING-LIBRARY"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--browser", "firefox"],
      "env": {}
    },
    "vitest": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@madrus/vitest-mcp-server@latest"],
      "env": {
        "VITEST_PROJECT_DIR": "/Users/arthurmelkonyan/webdev/vite-TESTING-LIBRARY/vite-starter"
      }
    }
  }
}
